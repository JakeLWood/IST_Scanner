{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/types/*": ["types/*"],
      "@/lib/*": ["lib/*"]
    }
  },
  "include": ["types/**/*.ts", "lib/**/*.ts"]
}
