# Supabase project URL – found in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key – found in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key – found in your Supabase project settings > API
# WARNING: This key bypasses RLS. Never expose it to the browser.
# Required for admin operations such as inviting new team members.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend API key – found at https://resend.com/api-keys
# Required for the "Share via Email" feature on the Screening Results page.
# WARNING: Never expose this key to the browser.
RESEND_API_KEY=re_your_resend_api_key

# The From address used when sharing screenings via email.
# Must be a verified sender in your Resend account (e.g. noreply@yourdomain.com).
RESEND_FROM_EMAIL=IST Screener <noreply@yourdomain.com>

# The public base URL of the application (used to build screening links in emails).
# In production this is your Vercel deployment URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic Claude API key — required for all IST analysis calls.
# WARNING: Never expose this key to the browser.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Resend inbound email webhook secret — used to verify webhook signatures.
# Found in your Resend Inbound settings after creating a webhook endpoint.
# Format: whsec_<base64-encoded-secret>
# Set the webhook URL in Resend to: https://your-app.vercel.app/api/email-intake
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_signing_secret

# Comma-separated admin email addresses to notify when an unregistered sender
# forwards a deal to screen@catalyze.partners.
# Leave blank to disable admin notifications.
ADMIN_NOTIFICATION_EMAIL=admin@catalyze.partners
