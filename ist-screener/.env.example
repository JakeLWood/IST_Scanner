# IST Screener — Environment Variables
# Copy this file to .env.local and fill in the actual values.
# NEVER commit .env.local to source control.
# PRD §2.4: The Claude API key must never be exposed to the client.

# Supabase connection
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic Claude API key (server-side only — never expose to client)
# PRD §2.4: All AI requests must route through a Supabase Edge Function or
# Vercel serverless function that holds this key server-side.
ANTHROPIC_API_KEY=sk-ant-your-key-here
